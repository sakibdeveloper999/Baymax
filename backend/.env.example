# Server Configuration
PORT=5000
NODE_ENV=development|production
API_BASE_URL=http://localhost:5000

# MongoDB Connection
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/baymax

# JWT Configuration
JWT_SECRET=min-32-char-random-string-for-access-tokens
JWT_REFRESH_SECRET=min-32-char-random-string-for-refresh-tokens
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# QR Service
QR_SECRET=min-32-char-random-string-for-hmac-sha256

# Receipt & Web URLs
RECEIPT_BASE_URL=http://localhost:3000/receipt

# CORS Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Printer Configuration
PRINTER_INTERFACE=192.168.1.100:9100
PRINTER_WIDTH=58mm

# Offline Database
OFFLINE_DB_PATH=./data/pos.db

# Socket.io
SOCKET_URL=http://localhost:5000

# Optional: Email & Payment Gateway
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
STRIPE_SECRET_KEY=sk_test_xxx

